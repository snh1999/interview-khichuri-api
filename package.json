  "name": "interview-khichuri",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:dev:rm": "podman-compose -f docker-compose.dev.yml down -v",
    "db:dev:up": "podman-compose -f docker-compose.dev.yml up db -d",
    "db:dev:reset": "npm run db:dev:rm && npm run db:dev:up && sleep 1 && npm run db:push",
    "db:test:push": "dotenv -e .env.test.web drizzle-kit push",
    "db:test:push:app": "dotenv -e .env.test.app -- sh -c 'rm -f \"${DATABASE_URL#file://}\" && drizzle-kit push'",
    "db:test:rm": "podman-compose -f docker-compose.test.yml down -v",
    "db:test:up": "podman-compose -f docker-compose.test.yml up test-db -d",
    "db:test:reset": "npm run db:test:rm && npm run db:test:up && sleep 1 && npm run db:test:push",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest",
    "test:cov": "vitest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/vitest --runInBand",
    "test:e2e:web": "npm run db:test:up && sleep 1 && npm run db:test:push && sleep 1 && vitest run --config vitest.e2e.config.ts --project web",
    "test:e2e:app": "npm run db:test:push:app && vitest run --config vitest.e2e.config.ts --project app",
    "test:e2e": "npm run db:test:up && sleep 1 && npm run db:test:push && npm run db:test:push:app && sleep 1 && vitest run --config vitest.e2e.config.ts"
  },
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED"
}
